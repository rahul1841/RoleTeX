# RoleTeX — example environment configuration.
# Copy to .env and fill in real values. NEVER commit a real .env (rule M-4).
# Numeric knobs are clamped server-side to the documented bounds (rule C-5).

# --- Mode & database -------------------------------------------------------
# MongoDB connection string. Unset/empty -> the app boots in single-user
# "demo mode" (no accounts, seed-resume tailoring only).
# Local docker-compose value: mongodb://localhost:27017
MONGODB_URI=
# Database name inside the Mongo deployment.
MONGODB_DB=jd_resume_builder

# --- Secrets ----------------------------------------------------------------
# Long random string. Derives the Fernet key that encrypts user API keys at
# rest. Unset -> a random ephemeral key is generated at boot (health reports
# checks.secret_key: "ephemeral") and stored keys become unreadable after a
# restart. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=

# --- Sessions & cookies ------------------------------------------------------
# Session lifetime in days (bounds 1-90).
SESSION_TTL_DAYS=30
# Secure flag on the session cookie: auto | true | false.
# auto -> Secure whenever the request scheme / X-Forwarded-Proto is https.
COOKIE_SECURE=auto

# --- Account policy ----------------------------------------------------------
# Allow new account registration (true/false).
ALLOW_REGISTRATION=true
# In multi-user mode, let users WITHOUT a stored key fall back to the
# operator's server-side env provider keys (true/false). Off by default.
ALLOW_ENV_KEY_FALLBACK=false

# --- Rate limits --------------------------------------------------------------
# LLM-cost bucket: tailor, resume import, run recompile.
# Calls per window (bounds 1-1000) / window seconds (bounds 10-3600).
RATE_LIMIT_LLM_CALLS=10
RATE_LIMIT_LLM_WINDOW_SECONDS=300
# General bucket: all other authenticated API calls.
# Calls per window (bounds 10-10000) / window seconds (bounds 1-3600).
RATE_LIMIT_GENERAL_CALLS=120
RATE_LIMIT_GENERAL_WINDOW_SECONDS=60
# Failed-login throttle per email+IP.
# Attempts (bounds 1-100) / window seconds (bounds 10-3600).
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_SECONDS=900

# --- Per-user quotas -----------------------------------------------------------
MAX_RESUMES_PER_USER=10          # bounds 1-100
MAX_VERSIONS_PER_RESUME=20       # bounds 1-100
MAX_JDS_PER_USER=50              # bounds 1-500
MAX_VERSIONS_PER_JD=20           # bounds 1-100 (archived history per JD; oldest pruned)
MAX_RUNS_PER_USER=200            # bounds 10-2000; oldest runs are pruned

# --- PDF import -----------------------------------------------------------------
# Upload cap in bytes (bounds 1MB-20MB).
MAX_PDF_UPLOAD_BYTES=10000000
# poppler pdftotext binary (name on PATH or absolute path).
PDFTOTEXT_BIN=pdftotext
# Extraction subprocess timeout in seconds (bounds 10-120).
PDF_EXTRACT_TIMEOUT_SECONDS=30

# --- LLM (existing knobs; see README for the full table) --------------------------
# Operator default provider. "mock" is deterministic and offline.
LLM_PROVIDER=mock
# Server-side operator keys (used in demo mode, and in multi-user mode only
# when ALLOW_ENV_KEY_FALLBACK=true). Users add their own keys in Settings.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# MISTRAL_API_KEY=
# CEREBRAS_API_KEY=
# LLM_MODEL=
